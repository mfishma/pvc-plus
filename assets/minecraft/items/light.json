{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:block_state",
    "block_state_property": "level",
    "cases": [
      { "when": "0",  "model": { "type": "minecraft:model", "model": "minecraft:item/light_00" } },
      { "when": "1",  "model": { "type": "minecraft:model", "model": "minecraft:item/light_01" } },
      { "when": "2",  "model": { "type": "minecraft:model", "model": "minecraft:item/light_02" } },
      { "when": "3",  "model": { "type": "minecraft:model", "model": "minecraft:item/light_03" } },
      { "when": "4",  "model": { "type": "minecraft:model", "model": "minecraft:item/light_04" } },
      { "when": "5",  "model": { "type": "minecraft:model", "model": "minecraft:item/light_05" } },
      { "when": "6",  "model": { "type": "minecraft:model", "model": "minecraft:item/light_06" } },
      { "when": "7",  "model": { "type": "minecraft:model", "model": "minecraft:item/light_07" } },
      { "when": "8",  "model": { "type": "minecraft:model", "model": "minecraft:item/light_08" } },
      { "when": "9",  "model": { "type": "minecraft:model", "model": "minecraft:item/light_09" } },
      { "when": "10", "model": { "type": "minecraft:model", "model": "minecraft:item/light_10" } },
      { "when": "11", "model": { "type": "minecraft:model", "model": "minecraft:item/light_11" } },
      { "when": "12", "model": { "type": "minecraft:model", "model": "minecraft:item/light_12" } },
      { "when": "13", "model": { "type": "minecraft:model", "model": "minecraft:item/light_13" } },
      { "when": "14", "model": { "type": "minecraft:model", "model": "minecraft:item/light_14" } },
      {
        "when": "15",
        "model": {
          "type": "minecraft:condition",
          "property": "minecraft:has_component",
          "component": "minecraft:enchantments",
          "on_true": {
            "type": "minecraft:select",
            "property": "minecraft:component",
            "component": "minecraft:enchantments",
            "cases": [
              {
                "when": {
                  "levels": {
                    "minecraft:thorns": 10
                  }
                },
                "model": {
                  "type": "minecraft:model",
                  "model": "pvc-plus:item/lux"
                }
              },
              {
                "when": {
                  "levels": {
                    "minecraft:thorns": 10
                  },
                  "show_in_tooltip": true
                },
                "model": {
                  "type": "minecraft:model",
                  "model": "pvc-plus:item/lux"
                }
              }
            ],
            "fallback": {
              "type": "minecraft:model",
              "model": "minecraft:item/light_15"
            }
          },
          "on_false": {
            "type": "minecraft:model",
            "model": "minecraft:item/light_15"
          }
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/light"
    }
  }
}
